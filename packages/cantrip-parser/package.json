{
  "name": "@cantrip/parser",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src --max-warnings 0",
    "check": "tsc -p tsconfig.json --noEmit && esint src --max-warnings 0",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@cantrip/ast": "workspace:*",
    "@cantrip/types": "workspace:*"
  },
  "devDependencies": {
    "typescript": "6.0.3"
  }
}
