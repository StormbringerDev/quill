{
  "name": "quill",
  "version": "0.1.0",
  "private": true,
  "description": "Quill - a lightweight scripting language",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "check": "turbo run check",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "repl": "pnpm --filter quill-repl-ts dev",
    "fmt": "prettier --write \"**/*.{ts,tsx,js,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.9.6",
    "turbo": "^2.10.5",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=20"
  }
}
