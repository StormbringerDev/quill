{
  "name": "cantrip-repl-ts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "quill-ts": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src --max-warnings 0",
    "check": "tsc -p tsconfig.json --noEmit && esint src --max-warnings 0",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@cantrip/interpreter": "workspace:*",
    "@cantrip/parser": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "4.23.1",
    "typescript": "7.0.2"
  }
}
