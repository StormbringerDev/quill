// examples/math.quill
// Basic arithmetic and a simple function.

print("=== Quill Math Demo ===");

let a = 40;
let b = 2;
print("a + b = " + (a + b));
print("a * b = " + (a * b));
print("a / b = " + (a / b));

fn add(x, y) {
  return x + y;
}

fn factorial(n) {
  if (n <= 1) {
    return 1;
  }
  return n * factorial(n - 1);
}

print("add(40, 2) = " + add(40, 2));
print("factorial(6) = " + factorial(6));
